# Copy this file to terraform.tfvars and fill in your actual values
# DO NOT commit terraform.tfvars to git (it contains secrets)

# AWS Configuration
aws_region     = "us-west-1"
aws_account_id = "407975137156"
project_name   = "rev-evalai"
environment    = "prod"

# Database Configuration
create_rds         = false # Set to true if you need Terraform to create RDS
existing_db_host   = "your-rds-endpoint.rds.amazonaws.com"
existing_db_port   = "5432"
db_name            = "evalai"
db_username        = "postgres"
db_password        = "your-secure-password"

# MongoDB Atlas Configuration
mongo_user     = "your-mongo-user"
mongo_password = "your-mongo-password"
mongo_cluster  = "your-cluster.mongodb.net"
mongo_db       = "evalai"
mongo_appname  = "EvalAI"

# WorkOS Configuration
workos_api_key         = "sk_live_..."
workos_client_id       = "client_..."
workos_default_org     = "org_..."
workos_cookie_password = "your-32-character-random-string"
workos_invite_url      = "https://your-authkit.authkit.app/invite"

# ElevenLabs Configuration (optional)
elevenlabs_api_key = "your-elevenlabs-api-key"
elevenlabs_voice_id = "s3TPKV1kjDlVtZbl4Ksh"

# AWS SQS Queue URLs
ai_quiz_sqs_queue_url       = "https://sqs.us-west-1.amazonaws.com/407975137156/rev-evalai-quiz-evaluation-queue"
test_service_sqs_queue_url  = "https://sqs.us-west-1.amazonaws.com/407975137156/rev-evalai-notification-service-queue"
notification_sqs_queue_url  = "https://sqs.us-west-1.amazonaws.com/407975137156/rev-evalai-notification-service-queue"

# AWS SES Configuration
ses_sender_email = "noreply@yourdomain.com"
ses_sender_name  = "Rev EvalAI"

# AWS Bedrock Configuration
bedrock_model_id    = "anthropic.claude-3-5-sonnet-20241022-v2:0"
bedrock_max_tokens  = 2048
bedrock_temperature = 0.7

# Image Tag (optional - defaults to 'latest')
# image_tag = "latest"

# Domain Configuration (optional - for custom domain with HTTPS)
# domain_name     = "evalai.yourdomain.com"
# certificate_arn = "arn:aws:acm:us-west-1:407975137156:certificate/..."

# Resource Tags
tags = {
  Project     = "Rev EvalAI"
  ManagedBy   = "Terraform"
  Environment = "production"
}
