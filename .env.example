#similar to configuration.property files, first step after initiating docker
# ------------------------------------------------------------------------------
# JWT (shared between user-service and api-gateway)
# ------------------------------------------------------------------------------
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# ------------------------------------------------------------------------------
# PostgreSQL (docker-compose)
# ------------------------------------------------------------------------------
POSTGRES_USER=root
POSTGRES_PASSWORD=root
POSTGRES_DB=eval_ai_dev

# ------------------------------------------------------------------------------
# MongoDB (docker-compose)
# ------------------------------------------------------------------------------
MONGO_USER=admin
MONGODB_PASSWORD=admin
MONGO_DB=evalai

# ------------------------------------------------------------------------------
# MinIO / S3 (docker-compose; AWS S3-compatible)
# ------------------------------------------------------------------------------
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=question-images
