# ------------------------------------------------------------------------------
# WorkOS Authentication (Required)
# ------------------------------------------------------------------------------
WORKOS_CLIENT_ID=client_your_client_id_here
WORKOS_API_KEY=sk_test_your_api_key_here
WORKOS_DEFAULT_ORG=org_your_org_id_here
WORKOS_COOKIE_PASSWORD=your_32_char_random_string_here

# ------------------------------------------------------------------------------
# Database Configuration (Docker Compose)
# ------------------------------------------------------------------------------
POSTGRES_USER=root
POSTGRES_PASSWORD=root
POSTGRES_DB=eval_ai_dev

# ------------------------------------------------------------------------------
# Database Configuration (Local Development - Optional)
# ------------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=eval_ai_test_management

# ------------------------------------------------------------------------------
# MongoDB Atlas (For Quiz and Question Management)
# ------------------------------------------------------------------------------
MONGO_USER=your_mongodb_user
MONGODB_PASSWORD=your_mongodb_password
MONGO_CLUSTER=your-cluster.mongodb.net
MONGO_APPNAME=EvalAI
MONGO_DB=evalai

# Optional MongoDB Connection Settings
MONGO_TIMEOUT_MS=5000
MONGO_MAX_POOL_SIZE=10
MONGO_MIN_POOL_SIZE=1

# ------------------------------------------------------------------------------
# AWS Bedrock Configuration (For AI Quiz Service)
# ------------------------------------------------------------------------------
# Optional if using IAM roles/instance profiles
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-west-1

# Bedrock Model Configuration
# Available models:
# - anthropic.claude-3-5-sonnet-20240620-v1:0 (Latest Sonnet)
# - anthropic.claude-3-sonnet-20240229-v1:0 (Sonnet - default)
# - anthropic.claude-3-haiku-20240307-v1:0 (Fastest, most cost-effective)
# - anthropic.claude-3-opus-20240229-v1:0 (Most capable, highest cost)
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_MAX_TOKENS=2048
BEDROCK_TEMPERATURE=0.7
